# App
PORT=8080

# Database
DB_URL=jdbc:mysql://localhost:3306/banking?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USER=root
DB_PASSWORD=root

# JPA
DDL_AUTO=update
SHOW_SQL=true

# CORS
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://localhost:5174

# Session cookie
# Local: Lax + false
# Production (frontend/backend on different domains): None + true
SESSION_COOKIE_SAME_SITE=Lax
SESSION_COOKIE_SECURE=false
